# LINE OA - ตัวอย่าง crontab
# ใส่ใน crontab -e แล้วแก้ค่าด้านล่างให้ตรงกับเครื่องคุณ
#
# สำคัญ: เพื่อให้ OpenClaw ส่งข้อความไป LINE ได้เมื่อรันจาก cron
# 1) ต้องให้ OpenClaw Gateway รันอยู่ตลอด (เช่น รันเป็น service / launchd) — ดู CRON_OPENCLAW.md
# 2) ต้องตั้ง HOME และ PATH ใน crontab ให้ตรงกับตอนรันด้วยมือ (เปิดเทอร์มินัลแล้ว echo $HOME และ echo $PATH)

SHELL=/bin/bash
# แก้เป็น home จริงของคุณ (เช่น /Users/yourname) — ใช้คำสั่ง echo $HOME ในเทอร์มินัลดู
HOME=/Users/YOUR_USERNAME
PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin

WORKSPACE="${HOME}/.openclaw/workspace/LineWebScraping"

# 1) ข้อความที่ยังไม่อ่าน: ทุก 1 ชม. 8:30, 9:30, ..., 17:30 (10 ครั้ง/วัน)
30 8-17 * * * /bin/bash "$WORKSPACE/run_line_oa_job.sh" >> "$WORKSPACE/logs/unread.log" 2>&1

# 2) อ่านแล้วแต่ยังไม่ตอบของวันนี้: ทุกวัน 17:35 ครั้งเดียว
35 17 * * * /bin/bash "$WORKSPACE/run_read_not_replied_daily.sh" >> "$WORKSPACE/logs/read_not_replied.log" 2>&1

# หมายเหตุ:
# - สร้างโฟลเดอร์ logs: mkdir -p "$WORKSPACE/logs"
# - .env ต้องมี LINE_OA_OPENCLAW_TARGET=webchat (หรือ target ที่ส่งไป LINE)
# - Timezone ตามระบบ (ดู: date หรือ timedatectl)
# - Windows: ใช้ Task Scheduler หรือ WSL+cron
