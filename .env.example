# คัดลอกเป็น .env แล้วใส่ค่าจริง (อย่า commit .env)
# cp .env.example .env

# LINE OA (หนึ่ง URL หรือหลายห้องคั่นด้วย comma)
LINE_OA_URL=
# หลายบัญชี: กำหนด port คั่น comma ให้สอดคล้องกับ LINE_OA_URL — ลิงก์แรกใช้ port แรก, ลิงก์ที่สองใช้ port ที่สอง
# ตัวอย่าง: LINE_OA_URL=https://chat.line.biz/xxx,https://chat.line.biz/yyy และ LINE_OA_PORTS=9222,9223 = เปิด xxx ใน port 9222, yyy ใน 9223
LINE_OA_PORTS=
# ส่งรายงานไป OpenClaw/ไลน์ — หนึ่ง target หรือหลาย target คั่นด้วย comma (เช่น webchat,line_group_2)
LINE_OA_OPENCLAW_TARGET=webchat
LINE_OA_INTERVAL=30
# ชื่อ "ของเรา" ตั้งค่าใน line_oa_unread_messages.py ที่ OUR_CHAT_HEADER_NAMES (เป็น list)

# Chrome สำหรับสคริปต์ (ใช้เมื่อมีบัญชีเดียว หรือไม่ตั้ง LINE_OA_PORTS)
CHROME_DEBUG_PORT=9222

# Facebook Inbox (Biz Web) — ใช้กับ facebook_unread_messages.py
FB_INBOX_URL=
# ส่งรายงาน Facebook ไป OpenClaw (หรือใช้ LINE_OA_OPENCLAW_TARGET ร่วมกัน)
FB_OPENCLAW_TARGET=
