# คัดลอกเป็น .env แล้วแก้ค่าตามต้องการ
# copy .env.example .env

# URL หน้าแชท LINE OA (LINE Business ID)
LINE_OA_URL=

# ระยะห่างในการตรวจสอบข้อความ (วินาที)
LINE_OA_INTERVAL=

# ใช้ Chrome ที่เปิดอยู่แล้ว: ใส่ 9222 แล้วเปิด Chrome ด้วย start_chrome_for_script.bat ก่อนรันสคริปต์
# CHROME_DEBUG_PORT=9222
