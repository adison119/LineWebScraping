# คัดลอกเป็น .env แล้วใส่ค่าจริง (อย่า commit .env)
# cp .env.example .env

# LINE OA (หนึ่ง URL หรือหลายห้องคั่นด้วย comma)
LINE_OA_URL=
# หลายบัญชี: กำหนด port คั่น comma ให้สอดคล้องกับ LINE_OA_URL — ลิงก์แรกใช้ port แรก, ลิงก์ที่สองใช้ port ที่สอง
# ตัวอย่าง: LINE_OA_URL=https://chat.line.biz/xxx,https://chat.line.biz/yyy และ LINE_OA_PORTS=9222,9223 = เปิด xxx ใน port 9222, yyy ใน 9223
LINE_OA_PORTS=
# ส่งรายงานไป OpenClaw/ไลน์ — หนึ่ง target หรือหลาย target คั่นด้วย comma (เช่น webchat,line_group_2)
LINE_OA_OPENCLAW_TARGET=webchat
LINE_OA_INTERVAL=30
# ชื่อ "ของเรา" ตั้งค่าใน line_oa_unread_messages.py ที่ OUR_CHAT_HEADER_NAMES (เป็น list)

# Chrome แยกตามแพลตฟอร์ม
# LINE OA: หลายบัญชีได้ — ใส่หลาย port คั่น comma (ถ้าไม่ตั้ง จะ fallback ไป CHROME_DEBUG_PORT)
LINE_OA_CHROME_DEBUG_PORT=9222,9223
# Facebook Inbox: บัญชีเดียวแต่หลาย URL ได้ — ใช้พอร์ตเดียวพอ (เปิด Chrome ตัวเดียว แล้วสคริปต์จะเปิดทีละ URL)
FB_CHROME_DEBUG_PORT=9224
# ค่าเดิม (ใช้เมื่อไม่ตั้ง LINE_OA_* / FB_* ด้านบน)
CHROME_DEBUG_PORT=9222

# Facebook Inbox (Biz Web) — หนึ่ง URL หรือหลาย URL คั่น comma (ใช้ Chrome พอร์ตเดียวจาก FB_CHROME_DEBUG_PORT)
FB_INBOX_URL=
# Facebook Inbox ใช้ LINE_OA_OPENCLAW_TARGET เดียวกัน (ไม่ต้องตั้ง FB_OPENCLAW_TARGET)
